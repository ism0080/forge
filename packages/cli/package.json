{
  "name": "@ism0080/forge-cli",
  "version": "0.1.3",
  "bin": {
    "forge": "dist/index.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "dev": "tsx src/index.ts",
    "publish:local": "pnpm build && pnpm publish --registry http://localhost:4873 --no-git-checks --tag local"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.80",
    "@ism0080/forge-core": "workspace:*",
    "@ism0080/forge-sdk": "workspace:*",
    "effect": "4.0.0-beta.80"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3"
  }
}
